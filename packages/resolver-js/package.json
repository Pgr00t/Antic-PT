{
  "name": "@antic-pt/resolver",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript Resolver SDK for the Anticipation Protocol (Antic-PT)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm,iife --global-name AnticPT --dts --clean",
